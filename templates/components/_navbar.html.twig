<header x-data="{ scrolled: false, mobileMenuOpen: false }" @scroll.window="scrolled = (window.pageYOffset > 50)" :class="scrolled ? 'bg-surface backdrop-blur-md shadow-sm border-b border-primary/15 py-3' : 'bg-primary py-5'" class="fixed w-full top-0 z-50 transition-all duration-500 ease-in-out">

	<div class="px-4 md:px-10 lg:px-14 mx-auto flex items-center justify-between">

		<div class="shrink-0 z-50">
			<a href="{{ path('app_home') }}" class="flex items-center no-underline group">
				<div class="relative w-15 h-17 flex items-center justify-center mr-4 transition-transform duration-300 group-hover:scale-105">
					<img src="{{ asset('images/logo/logo.svg') }}" :class="scrolled ? 'opacity-0' : 'opacity-100'" style="filter: drop-shadow(0px 0px 5px rgba(255, 255, 255, 0.4));" class="absolute inset-0 w-full h-full object-contain transition-all duration-500" alt="Brookes Institute"/>
					<img src="{{ asset('images/logo/logo.svg') }}" :class="scrolled ? 'opacity-100' : 'opacity-0'" class="absolute inset-0 w-full h-full object-contain transition-all duration-500" alt="Brookes Institute"/>
				</div>

				<div class="flex flex-col items-center ">
					<span :class="scrolled ? 'text-primary' : 'text-white'" class="block font-serif text-2xl font-extrabold uppercase tracking-[0.075em]  transition-colors duration-300">Brookes</span>
					<span :class="scrolled ? 'text-secondary' : 'text-secondary'" class="block font-sans text-sm tracking-[0.25em] uppercase font-bold  transition-colors duration-300">Institute</span>
				</div>
			</a>
		</div>
		<div class="hidden md:flex items-center space-x-10">
			<a href="{{ path('app_home') }}" :class="scrolled ? 'text-primary hover:text-secondary' : 'text-surface hover:text-secondary'" class="font-sans text-[11px] font-bold uppercase tracking-[0.2em] transition-colors duration-300">Accueil</a>
			<a href="{{ path('app_home') }}" :class="scrolled ? 'text-primary/70 hover:text-secondary' : 'text-surface hover:text-secondary'" class="font-sans text-[11px] font-bold uppercase tracking-[0.2em] transition-colors duration-300">À Propos</a>
			<a href="{{ path('app_home') }}" :class="scrolled ? 'text-primary/70 hover:text-secondary' : 'text-surface hover:text-secondary'" class="font-sans text-[11px] font-bold uppercase tracking-[0.2em] transition-colors duration-300">Formations</a>
			<a href="{{ path('app_home') }}" :class="scrolled ? 'bg-secondary text-surface hover:bg-primary' : 'bg-secondary text-primary hover:bg-surface'" class="px-7 py-4 font-sans text-[11px] font-bold uppercase tracking-[0.2em] transition-all rounded-sm shadow-md hover:-translate-y-0.5">Contact</a>
		</div>

        <button @click="mobileMenuOpen = !mobileMenuOpen" class="md:hidden z-50 p-2 focus:outline-none" :class="scrolled ? 'text-primary' : 'text-surface'">
			<svg class="w-8 h-8 transition-transform duration-300" fill="none" stroke="currentColor" viewbox="0 0 24 24">
				<path x-show="!mobileMenuOpen" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16m-7 6h7"/>
				<path x-show="mobileMenuOpen" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
			</svg>
		</button>
        <div x-show="mobileMenuOpen" x-transition:enter="transition ease-out duration-300" x-transition:enter-start="translate-x-full" x-transition:enter-end="translate-x-0" x-transition:leave="transition ease-in duration-300" x-transition:leave-start="translate-x-0" x-transition:leave-end="translate-x-full" class="fixed inset-0 bg-gradient-to-b from-primary to-primary/95 md:hidden flex flex-col items-center justify-start pt-28 space-y-6 z-40" style="display: none;">

			<a @click="mobileMenuOpen = false" href="{{ path('app_home') }}" class="text-white text-sm font-sans uppercase tracking-[0.2em] hover:text-secondary transition-colors duration-300">Accueil</a>
			<a @click="mobileMenuOpen = false" href="#about" class="text-white text-sm font-sans uppercase tracking-[0.2em] hover:text-secondary transition-colors duration-300">À Propos</a>
			<a @click="mobileMenuOpen = false" href="#programmes" class="text-white text-sm font-sans uppercase tracking-[0.2em] hover:text-secondary transition-colors duration-300">Formations</a>

			<a @click="mobileMenuOpen = false" href="#contact" class="bg-secondary text-primary hover:bg-white px-8 py-3 mt-2 font-sans text-xs font-bold uppercase tracking-[0.2em] rounded-sm transition-colors duration-300">Contact</a>

			<div class="mt-8 pt-6 border-t border-white/10 w-3/4 flex flex-col items-center">
				<p class="text-white/50 font-sans text-[10px] uppercase tracking-[0.2em] mb-3">Contact Direct</p>
				<a href="tel:+33683179487" class="flex items-center text-white hover:text-secondary transition-colors group">
					<svg class="w-4 h-4 mr-3 group-hover:animate-pulse" fill="none" stroke="currentColor" viewbox="0 0 24 24">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
					</svg>
					<span class="font-sans text-sm tracking-widest">06 83 17 94 87</span>
				</a>
			</div>

		</div>
	</div>
</header>
