{% extends 'base.html.twig' %}

{% block body %}
	<section class="relative w-full pt-[88px] h-screen flex flex-col items-center justify-center overflow-hidden bg-primary" x-data="{
						            activeSlide: 0,
						            slides: [
						                '/images/home-hero/photo-oxford.jpg',
						                '/images/home-hero/photo-aviation.jpg',
						                '/images/home-hero/photo-hotel.jpg',
						                '/images/home-hero/photo-conversation.jpg'
						            ],
						            init() {
						                setInterval(() => {
						                    this.activeSlide = (this.activeSlide + 1) % this.slides.length;
						                }, 5000);
						            }
						         }">

		<div class="absolute inset-0 z-0">
			<template x-for="(image, index) in slides" :key="index">
				<img :src="image" :class="activeSlide === index ? 'opacity-100 scale-100 z-10' : 'opacity-0 scale-105 z-0'" class="absolute inset-0 w-full h-full object-cover object-[center_top] transition-all duration-1000 ease-in-out" alt="Brookes Institute"/>
			</template>

			<div class="absolute inset-0 bg-linear-to-b from-primary/70 to-primary/30 z-10"></div>
		</div>
        <div class=" mx-auto px-4 md:px-8 lg:px-12 relative z-30 text-center flex flex-col items-center">
			<div x-data="{ shown: false }" x-init="setTimeout(() => shown = true, 300)" class=" flex flex-col items-center">


				<h1 :class="shown ? 'opacity-100 translate-y-0' : 'opacity-0 translate-y-8'" class="font-sans text-3xl md:text-4xl lg:text-5xl text-surface/80 font-bold mb-2 transition-all uppercase duration-1000 delay-200 ease-out leading-tight ">
					L’art de la conversation,
				</h1>

				<h2 :class="shown ? 'opacity-100 translate-y-0' : 'opacity-0 translate-y-8'" class="font-sans text-3xl md:text-4xl lg:text-5xl text-surface/60 font-bold mb-3 uppercase transition-all duration-1000 delay-400 ease-out leading-tight ">
					L'excellence de vos échanges.
				</h2>

				<p :class="shown ? 'opacity-100 translate-y-0' : 'opacity-0 translate-y-8'" class="font-sans text-lg md:text-xl text-secondary font-medium mb-10 transition-all duration-1000 delay-600 ease-out max-w-2xl">
					Apprenez l'anglais autrement : vivant, accessible, épanouissant.
				</p>

				<div :class="shown ? 'opacity-100 translate-y-0' : 'opacity-0 translate-y-8'" class="flex flex-col sm:flex-row justify-center gap-4 transition-all duration-1000 delay-800 ease-out">
					<a href="#programmes" class="bg-accent hover:bg-secondary text-surface px-8 py-4 text-center font-sans font-bold uppercase tracking-widest transition-colors duration-300 shadow-lg rounded-sm text-[11px]">
						Découvrez nos cours
					</a>
					<a href="#contact" class="border border-white/50 text-white hover:bg-white hover:text-primary px-8 py-4 text-center font-sans font-bold uppercase tracking-widest transition-colors duration-300 rounded-sm text-[11px] backdrop-blur-sm">
						Contact
					</a>
				</div>
			</div>
		</div>

		<div class="absolute bottom-8 left-1/2 transform -translate-x-1/2 z-30">
			<button @click="window.scrollTo({ top: $el.closest('section').nextElementSibling.offsetTop - 80, behavior: 'smooth' })" class="text-surface/60 hover:text-secondary transition-colors duration-300 animate-bounce focus:outline-none cursor-pointer" aria-label="Défiler vers le bas">
				<svg class="w-8 h-8" fill="none" stroke="currentColor" viewbox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"></path>
				</svg>
			</button>
		</div>
	</section>

    {# Ils nous font confiance #}
<section class="bg-white border-b border-gray-100 py-10">
    <div class="container mx-auto px-4 md:px-8 lg:px-12">
        <p class="text-center text-xs font-sans font-bold text-secondary uppercase tracking-widest mb-6">Ils nous font confiance</p>
        
        <div class="flex flex-wrap justify-center items-center gap-10 md:gap-20 opacity-50 grayscale hover:grayscale-0 transition-all duration-500">
            <div class="font-serif text-xl font-bold text-gray-800">FRANCE TRAVAIL</div>
            <div class="font-sans text-lg font-bold tracking-widest text-gray-800">HOTEL IBIS</div>
            <div class="font-serif text-xl italic text-gray-800">ADULT LEARNER</div>
            <div class="font-sans text-xl font-bold text-gray-800">BNP PARIBAS</div>
        </div>
    </div>
</section>

{# À propos #}
<section id="about" class="py-24 bg-surface overflow-hidden">
    <div class="container mx-auto px-4 md:px-8 lg:px-12">
        <div class="flex flex-col lg:flex-row items-center gap-16">

            <div class="w-full lg:w-5/12 relative group" x-data="{ shown: false }" x-intersect.once="shown = true">
                <div :class="shown ? 'opacity-100 translate-x-0' : 'opacity-0 -translate-x-12'" class="transition-all duration-1000 ease-out">
                    <div class="absolute inset-0 border-2 border-secondary translate-x-4 translate-y-4 rounded-sm transition-transform duration-700 ease-out group-hover:translate-x-8 group-hover:translate-y-8 pointer-events-none"></div>
                    <div class="relative bg-primary aspect-4/5 rounded-sm overflow-hidden z-10 shadow-xl">
                        <img src="https://images.unsplash.com/photo-1560250097-0b93528c311a?q=80&w=1000&auto=format&fit=crop" alt="Issa - Brookes Institute" class="object-cover w-full h-full grayscale group-hover:grayscale-0 scale-105 group-hover:scale-100 transition-all duration-1000 ease-out opacity-90 group-hover:opacity-100">
                    </div>
                </div>
            </div>

            <div class="w-full lg:w-7/12" x-data="{ shown: false }" x-intersect.once="shown = true">
                <div :class="shown ? 'opacity-100 translate-y-0' : 'opacity-0 translate-y-12'" class="transition-all duration-1000 delay-300 ease-out">
                    <span class="text-secondary font-sans uppercase tracking-[0.2em] text-sm font-bold mb-4 block">L'Expertise Fondatrice</span>
                    <h2 class="font-serif text-4xl md:text-5xl text-primary font-bold mb-8 leading-tight">Devenez la voix de <br>votre propre excellence.</h2>
                    
                    <div class="font-sans text-gray-700 leading-relaxed space-y-6 text-lg">
                        <p>Dans l'hôtellerie de luxe et le commerce international, l'anglais n'est pas qu'une simple compétence sur un CV. C'est l'outil de confiance qui transforme un bon service en une expérience client inoubliable.</p>
                        <p>Fort d'une solide expérience dans l'accompagnement des professionnels, j'ai fondé <strong class="text-primary">Brookes Institute</strong> avec une conviction : l'écrit s'apprend dans les livres, mais <strong class="text-accent italic">l'aisance relationnelle se forge par la parole</strong>.</p>
                    </div>

                    <div class="mt-10 border-l-2 border-secondary pl-6">
                        <p class="font-serif text-2xl text-primary italic">Issa Samake</p>
                        <p class="font-sans text-xs uppercase tracking-widest text-secondary mt-1 font-bold">Fondateur & Formateur</p>
                    </div>
                </div>
            </div>

        </div>
    </div>
</section>

{% endblock %}
