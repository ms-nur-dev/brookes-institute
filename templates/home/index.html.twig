					<div class="w-14 h-14 bg-surface rounded-sm flex items-center justify-center mb-8 group-hover:bg-primary transition-colors duration-500">
						<span class="text-2xl group-hover:scale-110 transition-transform duration-500">🤝</span>
					</div>
