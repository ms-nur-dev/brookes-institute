				<span :class="shown ? 'opacity-100 translate-y-0' : 'opacity-0 translate-y-8'" class="text-secondary font-sans uppercase tracking-[0.2em] text-sm font-bold mb-4 block transition-all duration-700 ease-out">L'Offre Brookes Institute</span>
				<h2 :class="shown ? 'opacity-100 translate-y-0' : 'opacity-0 translate-y-8'" class="font-serif text-4xl md:text-5xl text-primary font-bold mb-6 transition-all duration-700 delay-200 ease-out">Des programmes taillés pour l'excellence.</h2>
			</div>

			<div class="grid grid-cols-1 md:grid-cols-3 gap-8">
				<div x-data="{ shown: false }" x-intersect.once="shown = true" :class="shown ? 'opacity-100 translate-y-0' : 'opacity-0 translate-y-16'" class="group bg-white border border-primary/5 p-10 shadow-sm hover:shadow-xl transition-all duration-500 ease-out relative cursor-pointer delay-100">
