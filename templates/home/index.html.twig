			<h2 :class="shown ? 'opacity-100 translate-y-0' : 'opacity-0 translate-y-8'" class="font-serif text-4xl md:text-5xl text-primary font-bold mb-20 transition-all duration-700 delay-200 ease-out">
				Ils ont franchi le cap.
			</h2>

			<div class="grid grid-cols-1 lg:grid-cols-2 gap-10 max-w-6xl mx-auto text-left">

				<div :class="shown ? 'opacity-100 translate-y-0' : 'opacity-0 translate-y-12'" class="group bg-surface p-10 rounded-sm relative transition-all duration-500 hover:shadow-xl hover:-translate-y-1 delay-300">
					<svg class="absolute top-6 left-6 w-12 h-12 text-primary/5 transition-colors duration-500 group-hover:text-secondary/20" fill="currentColor" viewbox="0 0 32 32"><path d="M9.352 4C4.456 7.456 1 13.12 1 19.36c0 5.088 3.072 8.064 6.624 8.064 3.36 0 5.856-2.688 5.856-5.856 0-3.168-2.208-5.472-5.088-5.472-.576 0-1.344.096-1.536.192.48-3.264 3.552-7.104 6.624-9.024L9.352 4zm16.512 0c-4.8 3.456-8.256 9.12-8.256 15.36 0 5.088 3.072 8.064 6.624 8.064 3.264 0 5.856-2.688 5.856-5.856 0-3.168-2.304-5.472-5.184-5.472-.576 0-1.248.096-1.44.192.48-3.264 3.456-7.104 6.528-9.024L25.864 4z"/></svg>
