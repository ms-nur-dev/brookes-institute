{% extends 'base.html.twig' %}

{% block title %}{{ course.title }} - Brookes Institute{% endblock %}

{% block body %}
<section class="pt-40 pb-16 bg-surface relative overflow-hidden">
    <div class="absolute inset-0 z-0" style="background-image: radial-gradient(var(--color-primary) 0.5px, transparent 0.5px); background-size: 32px 32px; opacity: 0.03;"></div>

    <div class="container mx-auto px-4 md:px-8 lg:px-12 max-w-6xl relative z-10" x-data="{ shown: false }" x-init="setTimeout(() => shown = true, 100)">
        
        <div class="flex flex-col lg:flex-row justify-between items-start lg:items-end mb-16 gap-10">
            <div class="lg:w-2/3" :class="shown ? 'opacity-100 translate-y-0' : 'opacity-0 translate-y-8'" class="transition-all duration-700 ease-out">
                <span class="text-secondary font-sans uppercase tracking-[0.2em] text-xs md:text-sm font-bold mb-4 block flex items-center">
                    <span class="w-8 h-px bg-secondary mr-3"></span>
                    Réf: {{ course.ref }}
                </span>
                <h1 class="font-serif text-4xl md:text-5xl lg:text-6xl text-primary font-bold mb-6 leading-tight">
                    {{ course.title }}
                </h1>
                <p class="font-sans text-lg md:text-xl text-gray-600 max-w-2xl leading-relaxed">
                    {{ course.description }}
                </p>
            </div>
            
            <div class="lg:w-1/3 w-full bg-white p-8 border border-primary/5 rounded-sm shadow-xl" :class="shown ? 'opacity-100 translate-y-0' : 'opacity-0 translate-y-8'" class="transition-all duration-700 delay-200 ease-out">
                <div class="text-secondary font-sans uppercase tracking-widest text-xs font-bold mb-2">Investissement</div>
                <div class="text-4xl md:text-5xl font-bold text-primary mb-2">{{ course.price }}€</div>
                <div class="text-sm font-bold uppercase tracking-widest text-gray-500 mb-6">{{ course.hours }} Heures de formation</div>
                
                <a href="#programme" class="w-full inline-block text-center border border-primary text-primary hover:bg-primary hover:text-white py-4 font-sans text-xs font-bold uppercase tracking-[0.2em] transition-colors duration-300 rounded-sm">
                    Voir le programme
                </a>
            </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6" :class="shown ? 'opacity-100 translate-y-0' : 'opacity-0 translate-y-8'" class="transition-all duration-700 delay-400 ease-out">
            <div class="bg-white p-8 rounded-sm border border-primary/5 hover:border-secondary/30 transition-colors duration-300 group shadow-sm hover:shadow-md">
                <div class="text-primary/20 group-hover:text-secondary mb-5 transition-colors duration-300">
                    <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path></svg>
                </div>
                <h4 class="font-serif text-xl text-primary font-bold mb-3">Public & Prérequis</h4>
                <p class="font-sans text-sm text-gray-600 leading-relaxed">{{ course.public }}</p>
            </div>
            
            <div class="bg-white p-8 rounded-sm border border-primary/5 hover:border-secondary/30 transition-colors duration-300 group shadow-sm hover:shadow-md">
                <div class="text-primary/20 group-hover:text-secondary mb-5 transition-colors duration-300">
                    <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4"></path></svg>
                </div>
                <h4 class="font-serif text-xl text-primary font-bold mb-3">Modalités</h4>
                <p class="font-sans text-sm text-gray-600 leading-relaxed">{{ course.modalites }}</p>
            </div>
            
            <div class="bg-white p-8 rounded-sm border border-primary/5 hover:border-secondary/30 transition-colors duration-300 group shadow-sm hover:shadow-md">
                <div class="text-primary/20 group-hover:text-secondary mb-5 transition-colors duration-300">
                    <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"></path></svg>
                </div>
                <h4 class="font-serif text-xl text-primary font-bold mb-3">Évaluation</h4>
                <p class="font-sans text-sm text-gray-600 leading-relaxed">{{ course.evaluation }}</p>
            </div>
        </div>

    </div>
</section>

<section id="programme" class="py-24 bg-white" x-data="{ activeModule: 1 }">
    <div class="container mx-auto px-4 md:px-8 lg:px-12 max-w-4xl">
        <div class="text-center mb-16">
            <span class="text-secondary font-sans uppercase tracking-[0.2em] text-sm font-bold mb-4 block">Déroulé pédagogique</span>
            <h2 class="font-serif text-3xl md:text-4xl text-primary font-bold">Programme Détaillé</h2>
        </div>
        
        <div class="space-y-4">
            {% for module in course.modules %}
                <div class="bg-white border border-primary/10 rounded-sm overflow-hidden shadow-sm transition-all duration-300 hover:border-secondary/30">
                    
                    <button @click="activeModule = activeModule === {{ module.id }} ? null : {{ module.id }}" class="w-full text-left px-6 py-6 flex justify-between items-center focus:outline-none group">
                        <div class="flex items-center">
                            <span class="font-serif font-bold text-lg text-primary group-hover:text-secondary transition-colors">{{ module.title }}</span>
                            <span class="ml-4 px-3 py-1 bg-surface text-primary text-xs font-bold rounded-sm border border-primary/5">{{ module.duration }}</span>
                        </div>
                        <div class="shrink-0 ml-4">
                            <svg :class="activeModule === {{ module.id }} ? 'rotate-180 text-secondary' : 'text-primary/30'" class="w-6 h-6 transform transition-transform duration-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 9l-7 7-7-7"></path></svg>
                        </div>
                    </button>
                    
                    <div x-show="activeModule === {{ module.id }}" x-collapse class="px-6 pb-6 border-t border-gray-50 pt-6">
                        <p class="font-sans text-sm text-gray-800 mb-6 leading-relaxed">
                            <strong class="font-bold text-primary">Objectifs :</strong> {{ module.objectives }}
                        </p>
                        
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-6">
                            {% for chapter in module.chapters %}
                                <div class="flex items-start bg-surface p-3 rounded-sm">
                                    <svg class="w-4 h-4 text-secondary mt-0.5 mr-3 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
                                    <span class="text-sm text-gray-700">{{ chapter }}</span>
                                </div>
                            {% endfor %}
                        </div>

                        {% if module.modalites %}
                            <div class="text-xs text-gray-500 bg-gray-50 p-4 rounded-sm border-l-2 border-secondary">
                                <span class="font-bold text-primary uppercase tracking-widest text-[10px]">Modalités spécifiques :</span> 
                                <br>
                                {{ module.modalites }}
                            </div>
                        {% endif %}
                    </div>
                </div>
            {% endfor %}
        </div>

        <div class="mt-24 text-center border-t border-primary/10 pt-16">
            <h3 class="font-serif text-3xl md:text-4xl text-primary font-bold mb-6">Prêt à démarrer la {{ course.title }} ?</h3>
            <p class="text-sm text-gray-600 mb-10 max-w-2xl mx-auto leading-relaxed">
                Réservez un échange de 15 minutes avec Issa pour valider votre éligibilité et planifier le début de votre formation. 
                <br><br>
                <span class="italic text-xs">Accessibilité : Formations adaptées aux personnes en situation de handicap (Partenariat MDPH, Cap Emploi).</span>
            </p>
            
            <a href="" class="group inline-flex items-center justify-center bg-primary hover:bg-secondary text-white px-12 py-5 font-sans font-bold uppercase tracking-[0.2em] rounded-sm shadow-xl hover:-translate-y-1 transition-all duration-300 text-xs md:text-sm">
                Planifier mon diagnostic gratuit
                <svg class="w-5 h-5 ml-3 transform group-hover:translate-x-2 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg>
            </a>
        </div>
    </div>
</section>
{% endblock %}