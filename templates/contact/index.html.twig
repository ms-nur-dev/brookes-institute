{% extends 'base.html.twig' %}

{% block title %}Hello ContactController!{% endblock %}

{% block body %}
<section id="contact" class="py-24 pt-35 bg-surface relative overflow-hidden">
    <div class="container mx-auto px-4 md:px-8 lg:px-12 max-w-6xl relative z-10">
        
        <div class="text-center mb-16" x-data="{ shown: false }" x-intersect.once="shown = true">
            <span :class="shown ? 'opacity-100 translate-y-0' : 'opacity-0 translate-y-4'" class="text-secondary font-sans uppercase tracking-[0.2em] text-sm font-bold mb-4 block transition-all duration-700 ease-out">Contact</span>
            <h2 :class="shown ? 'opacity-100 translate-y-0' : 'opacity-0 translate-y-8'" class="font-serif text-4xl md:text-5xl text-primary font-bold transition-all duration-700 delay-200 ease-out">Vous souhaitez en savoir plus ?</h2>
        </div>

        <div class="bg-white rounded-sm shadow-xl border border-primary/5 overflow-hidden flex flex-col lg:flex-row" x-data="{ shown: false }" x-intersect.once="shown = true">
            
            <div :class="shown ? 'opacity-100 translate-x-0' : 'opacity-0 -translate-x-12'" class="lg:w-2/5 bg-primary text-white p-10 md:p-14 flex flex-col justify-between relative overflow-hidden transition-all duration-700 delay-300 ease-out z-10">
                {# <div class="absolute inset-0 opacity-10" style="background-image: radial-gradient(white 1px, transparent 1px); background-size: 24px 24px;"></div> #}
                
                <div class="relative z-10">
                    <h3 class="font-serif text-3xl font-bold mb-6">Parlons de vos objectifs.</h3>
                    <p class="font-sans text-white/80 mb-12 leading-relaxed">
                        Réservez votre diagnostic ou posez-nous vos questions. Nous vous répondrons personnellement dans les plus brefs délais.
                    </p>

                    <div class="space-y-8">
                        <div class="flex items-start">
                            <div class="w-12 h-12 bg-white/5 rounded-full flex items-center justify-center shrink-0 border border-white/10">
                                <svg class="w-5 h-5 text-secondary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
                            </div>
                            <div class="ml-4">
                                <p class="font-sans text-xs uppercase tracking-widest text-white/50 font-bold mb-1">E-mail</p>
                                <a href="mailto:brookes.institute02@gmail.com" class="font-sans text-base font-bold hover:text-secondary transition-colors">brookes.institute02@gmail.com</a>
                            </div>
                        </div>

                        <div class="flex items-start">
                            <div class="w-12 h-12 bg-white/5 rounded-full flex items-center justify-center shrink-0 border border-white/10">
                                <svg class="w-5 h-5 text-secondary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>
                            </div>
                            <div class="ml-4">
                                <p class="font-sans text-xs uppercase tracking-widest text-white/50 font-bold mb-1">Téléphone & WhatsApp</p>
                                <a href="tel:+33683179487" class="font-sans text-base font-bold hover:text-secondary transition-colors block">+33 6 83 17 94 87</a>
                                <a href="https://wa.me/33683179487" target="_blank" class="group/wa text-xs font-bold uppercase tracking-widest text-secondary hover:text-white transition-colors mt-2 inline-flex items-center">
                                    Discuter sur WhatsApp 
                                    <svg class="w-3 h-3 ml-2 transform group-hover/wa:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
                                </a>
                            </div>
                        </div>
                    </div>
                </div>

            </div>

            <div :class="shown ? 'opacity-100 translate-x-0' : 'opacity-0 translate-x-12'" class="lg:w-3/5 p-10 md:p-14 transition-all duration-700 delay-500 ease-out bg-white">
                <form action="#" method="POST" class="space-y-6">
                    
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div>
                            <label for="name" class="block font-sans text-xs font-bold uppercase tracking-widest text-primary mb-2">Votre nom</label>
                            <input type="text" id="name" name="name" class="w-full px-4 py-3 bg-surface/50 border border-gray-200 rounded-sm focus:bg-white focus:outline-none focus:border-secondary focus:ring-1 focus:ring-secondary transition-all text-gray-800" placeholder="Jean Dupont">
                        </div>
                        
                        <div>
                            <label for="phone" class="block font-sans text-xs font-bold uppercase tracking-widest text-primary mb-2">Téléphone</label>
                            <input type="tel" id="phone" name="phone" class="w-full px-4 py-3 bg-surface/50 border border-gray-200 rounded-sm focus:bg-white focus:outline-none focus:border-secondary focus:ring-1 focus:ring-secondary transition-all text-gray-800" placeholder="+33 6 00 00 00 00">
                        </div>
                    </div>

                    <div>
                        <label for="email" class="block font-sans text-xs font-bold uppercase tracking-widest text-primary mb-2">Adresse e-mail <span class="text-secondary">*</span></label>
                        <input type="email" id="email" name="email" required class="w-full px-4 py-3 bg-surface/50 border border-gray-200 rounded-sm focus:bg-white focus:outline-none focus:border-secondary focus:ring-1 focus:ring-secondary transition-all text-gray-800" placeholder="jean.dupont@entreprise.com">
                    </div>

                    <div>
                        <label for="message" class="block font-sans text-xs font-bold uppercase tracking-widest text-primary mb-2">Votre message <span class="text-secondary">*</span></label>
                        <textarea id="message" name="message" required rows="4" class="w-full px-4 py-3 bg-surface/50 border border-gray-200 rounded-sm focus:bg-white focus:outline-none focus:border-secondary focus:ring-1 focus:ring-secondary transition-all text-gray-800 resize-y" placeholder="Décrivez brièvement vos objectifs..."></textarea>
                    </div>

                    <div class="flex items-start pt-2">
                        <div class="flex items-center h-5">
                            <input id="rgpd" name="rgpd" type="checkbox" required class="w-4 h-4 text-secondary bg-surface border-gray-300 rounded-sm focus:ring-secondary focus:ring-2 cursor-pointer">
                        </div>
                        <div class="ml-3 text-sm">
                            <label for="rgpd" class="font-sans text-gray-500 text-xs leading-relaxed block cursor-pointer">
                                En cliquant sur « Envoyer », j'accepte que mes données soient utilisées pour traiter ma demande. Je peux retirer mon autorisation à tout moment. Notre <a href="#" class="text-primary border-b border-primary hover:text-secondary hover:border-secondary transition-colors">Politique de confidentialité</a> s'applique.
                            </label>
                        </div>
                    </div>

                    <div class="pt-4">
                        <button type="submit" class="w-full group inline-flex items-center justify-center bg-primary hover:bg-secondary text-white px-10 py-4 font-sans font-bold uppercase tracking-[0.2em] rounded-sm shadow-md hover:shadow-xl hover:-translate-y-1 transition-all duration-300 text-xs md:text-sm">
                            <span>Envoyer le message</span>
                            <svg class="w-4 h-4 ml-3 transform group-hover:translate-x-2 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg>
                        </button>
                    </div>
                </form>
            </div>

        </div>
    </div>
</section>
{% endblock %}
